# Gemini API Keys (5 different projects - each has separate quota)
# Format: key1,key2,key3,key4,key5
GEMINI_API_KEY=key1,key2,key3

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@host.neon.tech/dbname?sslmode=require

# Extractor Settings
# Using Gemini 3.1 Flash Lite: 15 RPM, 500 RPD (best for free tier)
BATCH_SIZE=25
DELAY_BETWEEN_REQUESTS=5
GEMINI_MODEL=gemini-3.1-flash-lite-preview


R2_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_access_key_here
R2_SECRET_ACCESS_KEY=your_secret_key_here
R2_BUCKET_NAME=website-images
R2_PUBLIC_URL=https://website.workers.dev

REVALIDATE_SECRET=node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Optional: Tesseract OCR Path (Windows)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
