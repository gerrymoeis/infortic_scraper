# Gemini API Keys (5 different projects - each has separate quota)
# Format: key1,key2,key3,key4,key5
GEMINI_API_KEY=key1,key2,key3

# OpenRouter API Keys (FALLBACK - 5 keys for redundancy)
# Format: sk-or-v1-xxx1,sk-or-v1-xxx2,sk-or-v1-xxx3
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEYS=sk-or-v1-key1,sk-or-v1-key2,sk-or-v1-key3

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@host.neon.tech/dbname?sslmode=require

# Instagram Passwords (for session re-authentication)
# One password per session (1-10)
INSTAGRAM_PASSWORD_1=password_for_session1
INSTAGRAM_PASSWORD_2=password_for_session2
INSTAGRAM_PASSWORD_3=password_for_session3
INSTAGRAM_PASSWORD_4=password_for_session4
INSTAGRAM_PASSWORD_5=password_for_session5

# Extractor Settings
# Using Gemini 3.1 Flash Lite: 15 RPM, 500 RPD (best for free tier)
BATCH_SIZE=25
DELAY_BETWEEN_REQUESTS=5
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# AI Service Configuration (Optimized for GitHub Actions)
# Primary service: 'gemini' (free tier) or 'openrouter' (faster, more stable)
PRIMARY_SERVICE=gemini
# Max retry attempts per service (reduced from 10 to 3 for faster failover)
MAX_RETRY_ATTEMPTS=3
# Max backoff time in seconds (reduced from 30 to 10)
MAX_BACKOFF_SECONDS=10


# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_access_key_here
R2_SECRET_ACCESS_KEY=your_secret_key_here
R2_BUCKET_NAME=infortic-images
R2_PUBLIC_URL=https://infortic-images.gerrymoeis.workers.dev

REVALIDATE_SECRET=node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Optional: Tesseract OCR Path (Windows)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
